{
  "name": "metamatrix",
  "version": "3.1.0",
  "private": true,
  "main": "main.js",
  "description": "MetaMatrix Desktop App",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@google/genai": "^1.29.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.1",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "react-virtuoso": "^4.18.3",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.munna.metamatrix",
    "productName": "MetaMatrix",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "src/server/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
